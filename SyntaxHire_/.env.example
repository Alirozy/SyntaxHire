DEBUG=True
SECRET_KEY=django-insecure-local-key...

# Docker Compose ve Django'nun ortak kullanacağı veritabanı değişkenleri
DB_NAME=my_django_db
DB_USER=my_db_user
DB_PASSWORD=my_secure_password
DB_HOST=db
DB_PORT=5432

# Django'nun (django-environ paketinin) okuyacağı URL formatı
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}